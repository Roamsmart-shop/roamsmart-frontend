# Roamsmart Digital Service - Frontend Environment Variables

# API Configuration (Required)
REACT_APP_API_URL=https://api.roamsmart.shop/api
REACT_APP_WS_URL=wss://api.roamsmart.shop

# App Configuration
REACT_APP_COMPANY_NAME=Roamsmart Digital Service
REACT_APP_COMPANY_EMAIL=support@roamsmart.shop
REACT_APP_COMPANY_PHONE=0557388622

# Feature Flags
REACT_APP_ENABLE_WHATSAPP_BOT=true
REACT_APP_ENABLE_AFA_REGISTRATION=true
REACT_APP_ENABLE_WAEC_VOUCHERS=true

# Optional: Analytics (if you add later)
# REACT_APP_GA_TRACKING_ID=G-XXXXXXXXXX

# Optional: Error Tracking
# REACT_APP_SENTRY_DSN=https://xxxxx@sentry.roamsmart.shop/1

# Optional: Map API (if you add location features)
# REACT_APP_GOOGLE_MAPS_API_KEY=your_key_here